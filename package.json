{
  "name": "my-vue3-demo",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "run-p type-check \"build-only {@}\" --",
    "preview": "vite preview",
    "build-only": "vite build",
    "type-check": "vue-tsc --build",
    "format": "prettier --write src/",
    "lint": "eslint . --ext .vue,.js,.jsx,.cjs,.mjs,.ts,.tsx,.cts,.mts --fix --ignore-path .gitignore",
    "lint:report": "eslint . --ext .vue,.js,.jsx,.cjs,.mjs,.ts,.tsx,.cts,.mts --ignore-path .gitignore --format html --output-file eslint-report.html",
    "type-check:watch": "vue-tsc --noEmit --watch"
  },
  "dependencies": {
    "@element-plus/icons-vue": "^2.3.2",
    "ahooks-vue": "^0.15.1",
    "axios": "^1.15.0",
    "codemirror": "^6.0.2",
    "codemirror-editor-vue3": "^2.8.0",
    "dayjs": "^1.11.20",
    "echarts": "^6.0.0",
    "element-plus": "^2.13.6",
    "file-saver": "^2.0.5",
    "html-docx-js-typescript": "^0.1.5",
    "lodash-es": "^4.18.1",
    "nprogress": "^0.2.0",
    "pinia": "^3.0.4",
    "vue": "^3.5.32",
    "vue-echarts": "^8.0.1",
    "vue-router": "^4.6.4",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@vitejs/plugin-vue": "^5.2.1",
    "@vitejs/plugin-vue-jsx": "^4.1.1",
    "vite": "^6.4.2",
    "typescript": "~5.8.3",
    "vue-tsc": "^2.2.12",
    "@vue/tsconfig": "^0.7.0",
    "prettier": "^3.8.1",
    "eslint": "^9.39.4",
    "@typescript-eslint/eslint-plugin": "^8.18.0",
    "@typescript-eslint/parser": "^8.18.0",
    "eslint-plugin-vue": "^9.32.0",
    "@vue/eslint-config-typescript": "^14.1.0",
    "sass": "^1.99.0",
    "sass-loader": "^8.0.2",
    "vite-plugin-vue-devtools": "^7.7.2",
    "npm-run-all2": "^7.0.2",
    "@tsconfig/node22": "^22.0.0",
    "@types/node": "^22.19.17"
  }
}
